{
  "name": "nudgepeek",
  "version": "0.3.0",
  "description": "Intimate photo sharing for small, private groups",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "pkill -f 'dist/electron \\.' 2>/dev/null; sleep 0.5; electron-vite build && electron .",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "release": "npm run build && electron-builder --publish always",
    "icons": "node scripts/create-placeholder-icons.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5",
    "electron": "^42.0.0",
    "electron-builder": "^26",
    "electron-vite": "^5",
    "eslint": "^9",
    "eslint-plugin-react": "^7",
    "eslint-plugin-react-hooks": "^7",
    "prettier": "^3",
    "typescript": "^6",
    "typescript-eslint": "^8",
    "vite": "^7"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2",
    "@types/libsodium-wrappers-sumo": "^0.7.8",
    "electron-updater": "^6",
    "libsodium-wrappers-sumo": "^0.8.4",
    "react": "^19",
    "react-dom": "^19",
    "zustand": "^5"
  }
}
